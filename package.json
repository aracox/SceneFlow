{
  "name": "sceneflow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SceneFlow — camera-to-map visual intelligence platform (frontend-only prototype with mock data)",
  "scripts": {
    "predev": "npm run generate:mock-movement && npm run generate:namtang-routes",
    "dev": "vite",
    "generate:mock-movement": "node scripts/generate-mock-movement.mjs",
    "generate:namtang-routes": "node scripts/generate-namtang-route-shapes.mjs",
    "prebuild": "npm run generate:mock-movement && npm run generate:namtang-routes",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "hls.js": "^1.6.16",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
